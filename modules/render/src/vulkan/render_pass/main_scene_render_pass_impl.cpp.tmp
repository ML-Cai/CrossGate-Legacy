#include "utils/pch.h"

#include "cgl/gui/window.h"
#include "renderer/vulkan/device_impl.h"
#include "renderer/vulkan/swapchain_impl.h"
#include "renderer/vulkan/command_buffer_list_impl.h"
#include "renderer/vulkan/framebuffer_impl.h"
#include "renderer/vulkan/common.h"
#include "renderer/vulkan/render_pass/main_scene_render_pass_impl.h"
#include "utils/logger_impl.h"
#include "utils/macros.h"

using cgl::vk::Device;
using cgl::vk::MainSceneRenderPass;

// -----------------------------------------------------------------------------
namespace {

const VkFormat DEPTH_FORMAT = VK_FORMAT_D32_SFLOAT;

}   // namespace

// -----------------------------------------------------------------------------
// cgl::vk::MainSceneRenderPass
// -----------------------------------------------------------------------------
MainSceneRenderPass::MainSceneRenderPass(
    const cgl::vk::IRenderPass::CreateInfo& createInfo)
    : cgl::vk::IRenderPass(createInfo),
      depthImage_(VK_NULL_HANDLE),
      depathImageMemory_(VK_NULL_HANDLE),
      depthImageView_(VK_NULL_HANDLE) {
}

MainSceneRenderPass::~MainSceneRenderPass() {
    destroy();
}

void MainSceneRenderPass::destroy() {
    auto pDevice = static_cast<cgl::vk::Device *>(createInfo().pDevice);

    CGL_SAFE_DESTROY_IMAGEVIEW(pDevice->device(), depthImageView_);
    CGL_SAFE_DESTROY_IMAGE(pDevice->device(), depthImage_);
    CGL_SAFE_FREE_MEMORY(pDevice->device(), depathImageMemory_);
    CGL_SAFE_DESTROY_RENDER_PASS(pDevice->device(), renderPass_);
}

bool MainSceneRenderPass::prepare() {
    CGL_CHECK_VALID_ARGUMENT(createInfo().pDevice != nullptr);
    CGL_CHECK_VALID_ARGUMENT(createInfo().pSwapchain != nullptr);
    CGL_CHECK_VALID_ARGUMENT(createInfo().pGeographicCoordSystem != nullptr);

    LOGI("Prepare MainSceneRenderPass ...");

    if (!createDepthResources()) return false;
    if (!createRenderPass()) return false;
    if (!createFramebuffer()) return false;

    return true;
}

bool MainSceneRenderPass::createDepthResources() {
    LOGD("Create Depth Resources ...");
    auto pDevice = static_cast<cgl::vk::Device *>(createInfo().pDevice);
    auto pSwapchain
        = static_cast<cgl::vk::Swapchain *>(createInfo().pSwapchain);

    if (pDevice->create2DImage(
            pSwapchain->extent().width,
            pSwapchain->extent().height,
            DEPTH_FORMAT,
            1,
            VK_IMAGE_TILING_OPTIMAL,
            VK_IMAGE_USAGE_DEPTH_STENCIL_ATTACHMENT_BIT,
            VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT,
            &depthImage_,
            &depathImageMemory_) == false) {
        LOGE("Failed to create the image for depth resource");
        return false;
    }

    if (pDevice->create2DImageView(
            depthImage_,
            DEPTH_FORMAT,
            1,
            VK_IMAGE_ASPECT_DEPTH_BIT,
            &depthImageView_) == false) {
        LOGE("Failed to create the imageview for depth resource");
        return false;
    }

    return true;
}

bool MainSceneRenderPass::createRenderPass() {
    LOGD("Create MainSceneRenderPass ...");

    auto pDevice = static_cast<cgl::vk::Device *>(createInfo().pDevice);
    auto pSwapchain
        = static_cast<cgl::vk::Swapchain *>(createInfo().pSwapchain);

    VkAttachmentDescription colorAttachment {
        .format         = pSwapchain->imageFormat(),
        .samples        = VK_SAMPLE_COUNT_1_BIT,
        .loadOp         = VK_ATTACHMENT_LOAD_OP_CLEAR,
        .storeOp        = VK_ATTACHMENT_STORE_OP_STORE,
        .stencilLoadOp  = VK_ATTACHMENT_LOAD_OP_DONT_CARE,
        .stencilStoreOp = VK_ATTACHMENT_STORE_OP_DONT_CARE,
        .initialLayout  = VK_IMAGE_LAYOUT_UNDEFINED,
        .finalLayout    = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR,
    };

    VkAttachmentReference colorAttachmentRef {
        .attachment = COLOR_ATTACTMENT_IDX,
        .layout     = VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL,
    };

    VkAttachmentDescription depthAttachment {
        .format         = DEPTH_FORMAT,
        .samples        = VK_SAMPLE_COUNT_1_BIT,
        .loadOp         = VK_ATTACHMENT_LOAD_OP_CLEAR,
        .storeOp        = VK_ATTACHMENT_STORE_OP_DONT_CARE,
        .stencilLoadOp  = VK_ATTACHMENT_LOAD_OP_DONT_CARE,
        .stencilStoreOp = VK_ATTACHMENT_STORE_OP_DONT_CARE,
        .initialLayout  = VK_IMAGE_LAYOUT_UNDEFINED,
        .finalLayout    = VK_IMAGE_LAYOUT_DEPTH_STENCIL_ATTACHMENT_OPTIMAL,
    };

    VkAttachmentReference depthAttachmentRef {
        .attachment = DEPTH_ATTACTMENT_IDX,
        .layout = VK_IMAGE_LAYOUT_DEPTH_STENCIL_ATTACHMENT_OPTIMAL,
    };

    VkSubpassDescription subpass {
        .pipelineBindPoint       = VK_PIPELINE_BIND_POINT_GRAPHICS,
        .colorAttachmentCount    = 1,
        .pColorAttachments       = &colorAttachmentRef,
        .pDepthStencilAttachment = &depthAttachmentRef,
    };

    VkSubpassDependency dependency {
        .srcSubpass    = VK_SUBPASS_EXTERNAL,
        .dstSubpass    = 0,
        .srcStageMask  = VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT,
        .dstStageMask  = VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT,
        .srcAccessMask = 0,
        .dstAccessMask = VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT,
    };

    std::array<VkAttachmentDescription, 2> attachments = {colorAttachment,
                                                          depthAttachment};
    VkRenderPassCreateInfo renderPassInfo {
        .sType           = VK_STRUCTURE_TYPE_RENDER_PASS_CREATE_INFO,
        .attachmentCount = static_cast<uint32_t>(attachments.size()),
        .pAttachments    = attachments.data(),
        .subpassCount    = 1,
        .pSubpasses      = &subpass,
        .dependencyCount = 1,
        .pDependencies   = &dependency,
    };

    RETURN_FAIL_IF_ANY_VK_FAILED(
        vkCreateRenderPass(pDevice->device(),
                           &renderPassInfo,
                           nullptr,
                           &renderPass_),
        "Failed to create render pass for MainScene");

    return true;
}

bool MainSceneRenderPass::createFramebuffer() {
    bool allBufferReady = false;
    auto pDevice = static_cast<cgl::vk::Device *>(createInfo().pDevice);
    auto pSwapchain
        = static_cast<cgl::vk::Swapchain *>(createInfo().pSwapchain);

    for (uint32_t i = 0; i < pSwapchain->imageCount() ; i++) {
        VkImageView attachments[] = {
            pSwapchain->swapChainImageView(i),
            depthImageView_
        };

        VkFramebufferCreateInfo framebufferInfo {
            .sType           = VK_STRUCTURE_TYPE_FRAMEBUFFER_CREATE_INFO,
            .renderPass      = renderPass_,
            .attachmentCount = 2,
            .pAttachments    = attachments,
            .width           = pSwapchain->extent().width,
            .height          = pSwapchain->extent().height,
            .layers          = 1,
        };

        // create vulkan buffer
        VkFramebuffer buffer;
        BREAK_IF_ANY_VK_FAILED(
            vkCreateFramebuffer(pDevice->device(),
                                &framebufferInfo,
                                nullptr,
                                &buffer),
            "Failed to create the framebuffer");

        // create cgl buffer object and assign VkFramebuffer to it
        auto pFramebuffer = cgl::IFramebuffer::create(pDevice,
                                                      this,
                                                      framebufferInfo.width,
                                                      framebufferInfo.height);
        if (pFramebuffer == nullptr) {
            LOGE("Failed to create framebuffer({}x{}) for render pass",
                 framebufferInfo.width, framebufferInfo.height);
            break;
        }

        auto pFramebufferImpl = reinterpret_cast<cgl::vk::Framebuffer *>(
                                    pFramebuffer.get());
        pFramebufferImpl->setBuffer(buffer);
        frameBufferList_.emplace_back(std::move(pFramebuffer));
        allBufferReady = true;
    }

    // check if all framebuffer create successfully, or release all allocated
    // buffer.
    if (!allBufferReady) {
        for (auto& buf : frameBufferList_) {
            auto pFramebufferImpl = reinterpret_cast<cgl::vk::Framebuffer *>(
                                    buf.get());
            vkDestroyFramebuffer(pDevice->device(),
                                 pFramebufferImpl->buffer(),
                                 nullptr);
        }
    }

    return allBufferReady;
}

bool MainSceneRenderPass::internalBegin() {
    // check input
    if ((beginInfo().pCmdBuffer == nullptr) ||
        (beginInfo().pFramebuffer == nullptr)) {
        LOGE("Invalid inputs");
        return false;
    }

    auto pFrameBuffer = static_cast<cgl::vk::Framebuffer*>(
                            beginInfo().pFramebuffer);
    std::array<VkClearValue, 2> clearValues{};
    clearValues[COLOR_ATTACTMENT_IDX].color = {{0.078f, 0.078f, 0.078f, 1.0f}};
    clearValues[DEPTH_ATTACTMENT_IDX].depthStencil = {1.0f, 0};

    VkRenderPassBeginInfo renderPassInfo {
        .sType       = VK_STRUCTURE_TYPE_RENDER_PASS_BEGIN_INFO,
        .renderPass  = renderPass_,
        .framebuffer = pFrameBuffer->buffer(),
        .renderArea  = VkRect2D{
            .offset = VkOffset2D {beginInfo().viewport.x,
                                  beginInfo().viewport.y},
            .extent = VkExtent2D {beginInfo().viewport.width,
                                  beginInfo().viewport.height}
        },
        .clearValueCount = static_cast<uint32_t>(clearValues.size()),
        .pClearValues    = clearValues.data(),
    };

    auto pVkCmdBuffer = static_cast<cgl::vk::CommandBuffer*>(
                            beginInfo().pCmdBuffer);
    vkCmdBeginRenderPass(pVkCmdBuffer->commandBuffer(), &renderPassInfo,
                         VK_SUBPASS_CONTENTS_INLINE);

    return true;
}

bool MainSceneRenderPass::internalEnd() {
    if (beginInfo().pCmdBuffer == nullptr) {
        LOGE("No command buffer begined for this render pass");
        return false;
    }

    auto pCmdBuffer = static_cast<cgl::vk::CommandBuffer*>(
                        beginInfo().pCmdBuffer);
    vkCmdEndRenderPass(pCmdBuffer->commandBuffer());

    return true;
}
